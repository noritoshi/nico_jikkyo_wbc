{
  "manifest_version": 3,
  "name": "Niko Jikkyo",
  "version": "0.17.0",
  "description": "2026 WBC Netflix配信をニコニコ実況コメントと一緒に楽しむためのChrome拡張。ニコニコ生放送のコメントをNetflix映像の上にニコニコ風に流します。",
  "permissions": [
    "offscreen",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.nicovideo.jp/*",
    "https://*.live.nicovideo.jp/*",
    "https://*.live2.nicovideo.jp/*",
    "https://www.netflix.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["src/content_script.js"],
      "css": ["src/content_style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Niko Jikkyo"
  }
}
